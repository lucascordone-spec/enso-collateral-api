{
  "name": "enso-collateral-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:mcp": "npm run build --workspace=@enso-collateral/mcp-server",
    "start:mcp": "npm run start --workspace=@enso-collateral/mcp-server",
    "build:eliza": "npm run build --workspace=eliza-plugin-enso-collateral",
    "build:dashboard": "npm run build --workspace=dashboard",
    "build:all": "npm run build:mcp && npm run build:eliza && npm run build:dashboard"
  }
}
